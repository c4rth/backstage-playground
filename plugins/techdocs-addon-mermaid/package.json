{
  "name": "@internal/plugin-techdocs-addon-mermaid",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "registry": "https://registry.npmjs.org"
  },
  "backstage": {
    "role": "frontend-plugin-module",
    "pluginId": "techdocs",
    "pluginPackage": "@backstage/plugin-techdocs"
  },
  "keywords": [
    "backstage",
    "techdocs",
    "mermaid"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "lint": "backstage-cli package lint",
    "test": "backstage-cli package test",
    "clean": "backstage-cli package clean",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack"
  },
  "dependencies": {
    "@backstage/core-plugin-api": "^1.12.2",
    "@backstage/plugin-techdocs-react": "^1.3.7",
    "@backstage/theme": "^0.7.1",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "mermaid": "^11.12.2"
  },
  "peerDependencies": {
    "@types/react": "^17.0.0 || ^18.0.0",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "react-router-dom": "^6.3.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@backstage/cli": "^0.35.3",
    "@backstage/plugin-techdocs-addons-test-utils": "^2.0.1",
    "@types/jest": "*",
    "@types/node": "*",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.3.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/johanneswuerbach/backstage-plugin-techdocs-addon-mermaid",
    "directory": "."
  },
  "packageManager": "yarn@4.8.1"
}
